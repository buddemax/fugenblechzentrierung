---
import type { Locale } from '~/i18n/content';
import { content } from '~/i18n/content';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = content[locale].benefits;
---

<section id="benefits" class="py-[clamp(5rem,10vw,9rem)] border-t border-ink-line">
  <div class="grid-frame">
    <div class="col-span-12 md:col-span-8 lg:col-span-6">
      <span class="label-blue">{t.eyebrow}</span>
      <h2 class="mt-6 text-display-lg font-display font-semibold leading-[0.98] text-balance">
        {t.headline}
      </h2>
    </div>

    <!-- Editorial list, not card grid -->
    <dl class="benefits-dl col-span-12 mt-16 md:mt-24 border-t border-b border-ink-line">
      {t.items.map((item, i) => (
        <Fragment>
          <dt class="benefits-dt">
            <span class="font-mono text-[0.75rem] tracking-wider text-ink-mute pt-1 benefits-num">{`0${i + 1}`}</span>
            <span class="benefits-title font-display text-2xl md:text-[2rem] font-semibold leading-[1.05] tracking-tight">
              {item.title}
            </span>
          </dt>
          <dd class="benefits-dd text-ink-soft text-[1.0625rem] leading-relaxed">
            {item.body}
          </dd>
        </Fragment>
      ))}
    </dl>
  </div>
</section>

<style>
  .benefits-dl {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    column-gap: 1rem;
  }
  @media (min-width: 768px) {
    .benefits-dl {
      column-gap: 2rem;
    }
  }
  .benefits-dt {
    grid-column: span 12 / span 12;
    display: grid;
    grid-template-columns: auto 1fr;
    column-gap: 1rem;
    padding-top: 2rem;
  }
  .benefits-dd {
    grid-column: span 12 / span 12;
    padding-bottom: 2rem;
    padding-top: 0.75rem;
    border-bottom: 1px solid var(--color-ink-line);
    max-width: 50ch;
  }
  .benefits-dt {
    border-top: 1px solid var(--color-ink-line);
  }
  .benefits-dt:first-of-type {
    border-top: 0;
  }
  @media (min-width: 768px) {
    .benefits-dt {
      grid-column: span 6 / span 6;
      padding-top: 2.5rem;
      padding-bottom: 2.5rem;
      border-top: 0;
      border-bottom: 1px solid var(--color-ink-line);
    }
    .benefits-dt:first-of-type {
      border-top: 0;
    }
    .benefits-dd {
      grid-column: span 6 / span 6;
      padding-top: 2.5rem;
      padding-bottom: 2.5rem;
      border-bottom: 1px solid var(--color-ink-line);
    }
  }
  .benefits-num {
    grid-column: 1;
    align-self: start;
  }
  .benefits-title {
    grid-column: 2;
  }
</style>
