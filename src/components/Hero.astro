---
import type { Locale } from '~/i18n/content';
import { content } from '~/i18n/content';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = content[locale];
---

<section class="relative overflow-hidden pt-12 md:pt-16 pb-16 md:pb-24">
  <!-- Faint grid background -->
  <div class="absolute inset-0 pointer-events-none opacity-[0.55]" aria-hidden="true">
    <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="hero-grid" width="80" height="80" patternUnits="userSpaceOnUse">
          <path d="M 80 0 L 0 0 0 80" fill="none" stroke="oklch(88% 0.006 230)" stroke-width="1"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#hero-grid)" />
    </svg>
  </div>

  <div class="grid-frame relative">
    <!-- Patent line -->
    <div class="col-span-12 flex items-center gap-3 mb-10 md:mb-14">
      <span class="label-blue">{t.hero.patentLabel}</span>
      <span class="h-px flex-1 bg-ink-line max-w-[120px]"></span>
      <span class="font-mono text-xs text-ink-soft tracking-wider">{t.hero.patentId}</span>
    </div>

    <!-- Headline -->
    <div class="col-span-12 lg:col-span-7 xl:col-span-7 relative z-10">
      <h1 class="text-display-xl font-display font-semibold text-balance">
        <span class="block">{t.hero.headlineLine1}</span>
        <span class="block">{t.hero.headlineLine2}</span>
        <span class="block text-blue italic" style="font-style: italic;">{t.hero.headlineLine3}</span>
      </h1>

      <p class="mt-8 md:mt-10 text-ink-soft text-[1.0625rem] md:text-lg leading-[1.55] max-w-[52ch]">
        {t.hero.sub}
      </p>

      <div class="mt-10 md:mt-12 flex flex-wrap items-center gap-x-10 gap-y-4">
        <a href="#contact" class="btn-primary">
          {t.hero.ctaPrimary}
          <span class="arrow">→</span>
        </a>
        <a href="#solution" class="btn-ghost">
          {t.hero.ctaSecondary}
          <span>↓</span>
        </a>
      </div>
    </div>

    <!-- Rendering -->
    <div class="col-span-12 lg:col-span-5 mt-12 lg:mt-0 relative">
      <div class="relative lg:-mt-16 xl:-mt-20">
        <!-- Corner marks framing the image -->
        <div class="relative aspect-square max-w-[520px] lg:max-w-none lg:ml-auto">
          <span class="corner-mark corner-mark--tl"></span>
          <span class="corner-mark corner-mark--tr"></span>
          <span class="corner-mark corner-mark--bl"></span>
          <span class="corner-mark corner-mark--br"></span>
          <img
            src="/Rendering_FBZ_No_BG.png"
            alt={t.hero.imgAlt}
            width="1200"
            height="1200"
            loading="eager"
            fetchpriority="high"
            decoding="async"
            class="w-full h-full object-contain select-none"
            draggable="false"
          />
        </div>

        <!-- Technical annotations -->
        <div class="hidden md:flex absolute right-2 -bottom-7 items-center gap-2 whitespace-nowrap">
          <span class="label text-[0.6875rem]">Formteil / Element</span>
          <span class="w-6 h-px bg-ink-soft"></span>
        </div>
      </div>
    </div>

    <!-- Spec row at bottom -->
    <div class="col-span-12 mt-16 md:mt-24 pt-6 border-t border-ink-line">
      <div class="flex items-start justify-between gap-6 mb-5">
        <span class="label">{t.hero.specLabel}</span>
      </div>
      <dl class="grid grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-6">
        {t.hero.specItems.map((item) => (
          <div class="flex flex-col gap-1">
            <dt class="label text-[0.6875rem]">{item.k}</dt>
            <dd class="font-display text-lg md:text-xl font-medium text-ink tracking-tight">{item.v}</dd>
          </div>
        ))}
      </dl>
    </div>
  </div>
</section>
