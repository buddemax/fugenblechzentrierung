---
import type { Locale } from '~/i18n/content';
import { content } from '~/i18n/content';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = content[locale].problem;
---

<section id="problem" class="py-[clamp(5rem,10vw,9rem)] border-t border-ink-line">
  <!-- Stats block: sticky headline scoped to this grid only -->
  <div class="grid-frame">
    <div class="col-span-12 lg:col-span-4 lg:sticky lg:top-24 self-start">
      <span class="label-blue">{t.eyebrow}</span>
      <h2 class="mt-6 text-display-md font-display font-semibold text-balance leading-[1.02]">
        {t.headline}
      </h2>
    </div>

    <div class="col-span-12 lg:col-span-7 lg:col-start-6 mt-8 lg:mt-0">
      <p class="text-ink-soft text-lg leading-relaxed max-w-[58ch]">
        {t.lead}
      </p>

      <article
        class="relative mt-14 md:mt-16 border p-8 md:p-10"
        style="background: var(--color-paper-warm); border-color: var(--color-paper-warm-line);"
      >
        <span class="corner-mark corner-mark--tl" aria-hidden="true"></span>
        <span class="corner-mark corner-mark--tr" aria-hidden="true"></span>
        <span class="label-blue">{t.keyInsight.eyebrow}</span>
        <h3 class="mt-5 font-display text-2xl md:text-[1.875rem] font-semibold leading-[1.15] text-balance max-w-[32ch]">
          {t.keyInsight.title}
        </h3>
        <p class="mt-5 max-w-[52ch] text-ink-soft text-[1.0625rem] leading-relaxed">
          {t.keyInsight.body}
        </p>
        <p class="mt-6 label text-[0.6875rem]">
          {locale === 'de' ? 'Quelle' : 'Source'} — {t.keyInsight.source}
        </p>
      </article>

      <div class="mt-16 space-y-12 md:space-y-16">
        {t.stats.map((stat, i) => (
          <div class="relative">
            <div class="flex items-baseline gap-3">
              <span class="num-mega text-blue" set:html={stat.value.replace(/[–-]/g, '<span class="num-dash">–</span>')} />
              <span class="font-display text-3xl md:text-5xl font-medium text-ink-soft">{stat.unit}</span>
            </div>
            <p class="mt-4 max-w-[44ch] text-ink-soft text-[1.0625rem] leading-snug">
              {stat.label}
            </p>
            <p class="mt-3 label text-[0.6875rem]">
              {locale === 'de' ? 'Quelle' : 'Source'} — {stat.source}
            </p>
            {i < t.stats.length - 1 && <div class="mt-12 md:mt-16 h-px bg-ink-line" />}
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Error sources: separate grid so sticky above is released -->
  <div class="grid-frame mt-24 md:mt-32">
    <div class="col-span-12 lg:col-span-4">
      <h3 class="font-display text-2xl md:text-3xl font-semibold leading-tight text-balance">
        {t.errors.title}
      </h3>
      <p class="mt-5 text-ink-mute text-[0.9375rem] leading-relaxed max-w-[40ch]">
        {t.errors.intro}
      </p>
    </div>
    <ol class="col-span-12 lg:col-span-8 lg:col-start-5 grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-10 mt-8 lg:mt-0">
      {t.errors.items.map((item) => (
        <li class="relative pt-5 border-t border-ink">
          <span class="font-mono text-[0.75rem] tracking-wider text-ink-mute">{item.num}</span>
          <h4 class="mt-3 font-display text-xl font-semibold leading-tight">{item.title}</h4>
          <p class="mt-2 text-ink-soft text-[0.9375rem] leading-snug max-w-[36ch]">{item.body}</p>
        </li>
      ))}
    </ol>
  </div>
</section>
