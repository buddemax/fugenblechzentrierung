---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/Header.astro';
import Hero from '~/components/Hero.astro';
import Intro from '~/components/Intro.astro';
import Problem from '~/components/Problem.astro';
import Solution from '~/components/Solution.astro';
import Detail from '~/components/Detail.astro';
import Benefits from '~/components/Benefits.astro';
import Cost from '~/components/Cost.astro';
import Applications from '~/components/Applications.astro';
import Credibility from '~/components/Credibility.astro';
import CTASection from '~/components/CTASection.astro';
import Footer from '~/components/Footer.astro';
---

<Layout locale="en">
  <Header locale="en" />
  <main id="main">
    <Hero locale="en" />
    <Intro locale="en" />
    <Problem locale="en" />
    <Solution locale="en" />
    <Detail locale="en" />
    <Benefits locale="en" />
    <Cost locale="en" />
    <Applications locale="en" />
    <Credibility locale="en" />
    <CTASection locale="en" />
  </main>
  <Footer locale="en" />
</Layout>
