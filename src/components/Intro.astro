---
import type { Locale } from '~/i18n/content';
import { content } from '~/i18n/content';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = content[locale].intro;
const facts = [t.factA, t.factB, t.factC];
---

<section
  id="about"
  aria-labelledby="intro-eyebrow"
  class="py-[clamp(3.5rem,7vw,6rem)] border-t border-ink-line bg-[oklch(97%_0.005_230)]"
>
  <div class="grid-frame">
    <div class="col-span-12 lg:col-span-4">
      <h2 id="intro-eyebrow" class="label-blue">
        {t.eyebrow}
      </h2>
    </div>

    <div class="col-span-12 lg:col-span-8">
      <p class="text-ink text-[1.0625rem] md:text-lg leading-[1.65] max-w-[68ch]">
        {t.body}
      </p>

      <dl class="intro-dl mt-10 md:mt-12 border-t border-ink-line pt-6">
        {facts.map((fact) => (
          <Fragment>
            <dt class="label text-[0.6875rem]">{fact.k}</dt>
            <dd class="font-display text-base md:text-lg font-medium text-ink leading-snug tracking-tight">{fact.v}</dd>
          </Fragment>
        ))}
      </dl>
    </div>
  </div>
</section>

<style>
  .intro-dl {
    display: grid;
    grid-template-columns: 1fr;
    row-gap: 0.375rem;
  }
  .intro-dl dd + dt {
    margin-top: 1.25rem;
  }
  @media (min-width: 768px) {
    .intro-dl {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      grid-template-rows: auto auto;
      grid-auto-flow: column;
      column-gap: 1.5rem;
      row-gap: 0.375rem;
    }
    .intro-dl dd + dt {
      margin-top: 0;
    }
  }
</style>
