---
import type { Locale } from '~/i18n/content';
import { content } from '~/i18n/content';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = content[locale];
const otherLocale: Locale = locale === 'de' ? 'en' : 'de';
const otherHref = otherLocale === 'de' ? '/' : '/en/';
---

<header class="sticky top-0 z-40 backdrop-blur-md bg-paper/95 border-b border-ink-line">
  <div class="grid-frame items-center py-4 md:py-5" style="grid-template-columns: auto 1fr auto;">
    <a href={locale === 'de' ? '/' : '/en/'} class="flex items-center gap-3 group" aria-label="FBZ Fugenblechzentrierung">
      <img
        src="/Logo_FBZ_No_BG.png"
        alt=""
        width="32"
        height="32"
        class="h-8 w-auto select-none"
        draggable="false"
      />
      <span class="font-display font-semibold text-[1.0625rem] tracking-tight">FBZ</span>
      <span class="hidden sm:inline text-ink-mute text-sm">Fugenblechzentrierung</span>
    </a>

    <nav class="hidden md:flex justify-center gap-8 text-sm text-ink-soft">
      <a href="#problem" class="hover:text-blue transition-colors">{t.nav.problem}</a>
      <a href="#solution" class="hover:text-blue transition-colors">{t.nav.solution}</a>
      <a href="#benefits" class="hover:text-blue transition-colors">{t.nav.benefits}</a>
      <a href="#contact" class="hover:text-blue transition-colors">{t.nav.contact}</a>
    </nav>

    <div class="flex items-center gap-5">
      <a href={otherHref} class="label hover:text-blue transition-colors" aria-label={`Switch to ${otherLocale.toUpperCase()}`}>
        <span class="text-ink">{locale.toUpperCase()}</span>
        <span class="mx-1.5 text-ink-line">/</span>
        <span>{otherLocale.toUpperCase()}</span>
      </a>
      <a href="#contact" class="hidden sm:inline-flex btn-primary !py-2.5 !px-4 text-[0.8125rem]">
        {t.hero.ctaPrimary}
        <span class="arrow">→</span>
      </a>
    </div>
  </div>
</header>
