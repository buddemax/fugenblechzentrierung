---
import type { Locale } from '~/i18n/content';
import { content } from '~/i18n/content';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = content[locale].credibility;
---

<section class="py-[clamp(5rem,10vw,9rem)] border-t border-ink-line">
  <div class="grid-frame">
    <div class="col-span-12 lg:col-span-7">
      <span class="label-blue">{t.eyebrow}</span>
      <h2 class="mt-6 text-display-md font-display font-semibold leading-[1.02] text-balance">
        {t.headline}
      </h2>
      <p class="mt-8 text-ink-soft text-[1.0625rem] md:text-lg leading-relaxed max-w-[58ch]">
        {t.body}
      </p>
    </div>

    <dl class="col-span-12 lg:col-span-5 mt-12 lg:mt-0 lg:pt-2">
      <div class="border-t border-ink">
        {t.facts.map((fact) => (
          <div class="grid grid-cols-12 gap-4 py-5 border-b border-ink-line">
            <dt class="col-span-5 label text-[0.6875rem] pt-1">{fact.k}</dt>
            <dd class="col-span-7 font-display text-base md:text-lg font-medium text-ink leading-tight">{fact.v}</dd>
          </div>
        ))}
      </div>
    </dl>
  </div>
</section>
