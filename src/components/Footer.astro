---
import type { Locale } from '~/i18n/content';
import { content } from '~/i18n/content';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = content[locale].footer;
const year = new Date().getFullYear();
const legalHref = locale === 'de' ? '/impressum/' : '/en/legal-notice/';
const privacyHref = locale === 'de' ? '/datenschutz/' : '/en/privacy/';
const privacyLabel = locale === 'de' ? 'Datenschutz' : 'Privacy';
---

<footer class="py-14 md:py-16 border-t border-ink-line">
  <div class="grid-frame">
    <div class="col-span-12 md:col-span-6">
      <div class="flex items-center gap-3">
        <svg width="22" height="22" viewBox="0 0 32 32" fill="none" aria-hidden="true">
          <rect x="2" y="2" width="28" height="28" stroke="currentColor" stroke-width="1.5"/>
          <line x1="16" y1="2" x2="16" y2="30" stroke="currentColor" stroke-width="1.5"/>
          <line x1="14" y1="8" x2="18" y2="8" stroke="currentColor" stroke-width="1"/>
          <line x1="14" y1="24" x2="18" y2="24" stroke="currentColor" stroke-width="1"/>
        </svg>
        <span class="font-display font-semibold text-base">FBZ Fugenblechzentrierung</span>
      </div>
      <div class="mt-5 text-sm text-ink-soft leading-relaxed">
        <p class="font-medium text-ink">{t.company}</p>
        <p>{t.address}</p>
      </div>
    </div>

    <div class="col-span-12 md:col-span-6 mt-8 md:mt-0 md:text-right flex flex-col md:items-end gap-5">
      <p class="label text-[0.6875rem]">{t.patent}</p>
      <nav class="flex gap-6 text-xs text-ink-soft" aria-label={locale === 'de' ? 'Rechtliches' : 'Legal'}>
        <a href={legalHref} class="hover:text-blue transition-colors">{t.legal}</a>
        <a href={privacyHref} class="hover:text-blue transition-colors">{privacyLabel}</a>
      </nav>
      <p class="text-xs text-ink-mute">© {year} BBA GmbH</p>
    </div>
  </div>
</footer>
