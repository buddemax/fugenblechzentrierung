---
import type { Locale } from '~/i18n/content';
import { content } from '~/i18n/content';
import VideoHero from '~/components/VideoHero.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = content[locale];
---

<section class="relative overflow-hidden pt-12 md:pt-16 pb-16 md:pb-24">
  <!-- Faint grid background -->
  <div class="absolute inset-0 pointer-events-none opacity-[0.55]" aria-hidden="true">
    <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="hero-grid" width="80" height="80" patternUnits="userSpaceOnUse">
          <path d="M 80 0 L 0 0 0 80" fill="none" stroke="oklch(88% 0.006 230)" stroke-width="1"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#hero-grid)" />
    </svg>
  </div>

  <div class="grid-frame relative">
    <!-- Patent line -->
    <div class="col-span-12 flex items-center gap-4 mb-10 md:mb-14">
      <span class="inline-flex items-center gap-2 px-3 py-1.5 border-2 border-blue text-blue font-mono text-[0.8125rem] md:text-sm font-bold uppercase tracking-[0.14em] bg-blue/5">
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-blue animate-pulse"></span>
        {t.hero.patentLabel}
      </span>
      <span class="h-px flex-1 bg-ink-line max-w-[120px]"></span>
      <span class="font-mono text-xs md:text-sm font-semibold text-ink tracking-wider">{t.hero.patentId}</span>
    </div>

    <!-- Headline -->
    <div class="col-span-12 lg:col-span-6 xl:col-span-6 relative z-10 lg:pr-6 xl:pr-10">
      <h1 class="hero-headline font-display font-semibold text-balance">
        <span class="block">{t.hero.headlineLine1}</span>
        <span class="block hero-headline__wrap">{t.hero.headlineLine2}</span>
        <span class="block text-blue italic" style="font-style: italic;">{t.hero.headlineLine3}</span>
      </h1>

      <p class="mt-7 md:mt-9 text-ink-soft text-[1.0625rem] md:text-lg leading-[1.55] max-w-[44ch]">
        {t.hero.sub}
      </p>

      <div class="mt-9 md:mt-11 flex flex-wrap items-center gap-x-8 gap-y-4">
        <a href="#contact" class="btn-primary">
          {t.hero.ctaPrimary}
          <span class="arrow">→</span>
        </a>
        <a href="#solution" class="btn-ghost">
          {t.hero.ctaSecondary}
          <span>↓</span>
        </a>
      </div>
    </div>

    <!-- Video stage (replaces hero rendering) -->
    <div class="col-span-12 lg:col-span-6 mt-12 lg:mt-0 relative">
      <div class="hero-video-bleed relative lg:-mt-10 xl:-mt-12">
        <VideoHero locale={locale} />
      </div>
    </div>

    <!-- Spec row at bottom -->
    <div class="col-span-12 mt-16 md:mt-24 pt-6 border-t border-ink-line">
      <div class="flex items-start justify-between gap-6 mb-5">
        <span class="label">{t.hero.specLabel}</span>
      </div>
      <dl class="hero-spec-dl">
        {t.hero.specItems.map((item) => (
          <Fragment>
            <dt class="label text-[0.6875rem]">{item.k}</dt>
            <dd class="font-display text-lg md:text-xl font-medium text-ink tracking-tight">{item.v}</dd>
          </Fragment>
        ))}
      </dl>
    </div>
  </div>
</section>

<style>
  /* Hero headline scale — compact on small viewports, dominant on mid,
     gracefully capped on very large so it does not crush video real estate. */
  .hero-headline {
    font-size: clamp(2.5rem, 4.6vw, 4.5rem);
    line-height: 0.98;
    letter-spacing: -0.025em;
    color: var(--color-ink);
  }

  /* Long German compounds like "Millimetergenau" need word-level wrapping
     when the column gets tight. Hyphenation only kicks in if the line
     overflows, otherwise the word stays whole. */
  .hero-headline__wrap {
    hyphens: auto;
    -webkit-hyphens: auto;
    overflow-wrap: anywhere;
    word-break: normal;
  }

  /* Bleed video to viewport right edge across all breakpoints,
     so on 16"/15"/27" screens the video remains visually dominant
     instead of being capped at the 1440px grid-frame. */
  @media (min-width: 1024px) {
    .hero-video-bleed {
      margin-right: calc(
        min(0px, (1440px - 100vw) / 2)
        - clamp(1.25rem, 4vw, 3rem)
      );
    }
  }

  .hero-spec-dl {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    grid-template-rows: auto auto;
    grid-auto-flow: column;
    column-gap: 1.5rem;
    row-gap: 0.25rem;
  }
  .hero-spec-dl dd {
    margin-bottom: 1.25rem;
  }
  @media (min-width: 768px) {
    .hero-spec-dl {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
    .hero-spec-dl dd {
      margin-bottom: 0;
    }
  }
</style>
