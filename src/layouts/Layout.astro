---
import '~/styles/global.css';
import type { Locale } from '~/i18n/content';
import { content } from '~/i18n/content';
import WebMCP from '~/components/WebMCP.astro';

interface Props {
  locale: Locale;
  pageType?: 'home' | 'legal';
  title?: string;
  description?: string;
  noindex?: boolean;
  path?: string;
}

const { locale, pageType = 'home', title, description, noindex = false, path = '' } = Astro.props;
const t = content[locale];
const altLocale: Locale = locale === 'de' ? 'en' : 'de';

const baseDe = 'https://www.fb-zent.com';
const baseEn = 'https://www.fb-zent.com/en';
const canonical = (locale === 'de' ? baseDe : baseEn) + (path ? `/${path}` : '/');
const altHref = (altLocale === 'de' ? baseDe : baseEn) + (path ? `/${path}` : '/');

const pageTitle = title ?? t.meta.title;
const pageDescription = description ?? t.meta.description;
const ogImage = 'https://www.fb-zent.com/og-image.png';

const founderNode = {
  '@type': 'Person',
  '@id': 'https://www.fb-zent.com/#founder',
  name: 'Dr.-Ing. Jörn Budde',
  honorificPrefix: 'Dr.-Ing.',
  givenName: 'Jörn',
  familyName: 'Budde',
  jobTitle: locale === 'de'
    ? 'Öffentlich bestellter und vereidigter Sachverständiger für Gebäudeabdichtung und Bautenschutz'
    : 'Court-appointed and sworn expert for building waterproofing and structural protection',
  worksFor: { '@id': 'https://www.fb-zent.com/#org' },
  knowsAbout: locale === 'de'
    ? ['Gebäudeabdichtung', 'Bautenschutz', 'WU-Konstruktionen', 'Weiße Wanne', 'Fugenabdichtung', 'Arbeitsfugen', 'Bauschadensbegutachtung']
    : ['Building waterproofing', 'Structural protection', 'Watertight concrete construction', 'Construction-joint sealing', 'Building defect expertise'],
  hasCredential: [
    {
      '@type': 'EducationalOccupationalCredential',
      credentialCategory: locale === 'de' ? 'Promotion (Dr.-Ing.)' : 'Doctorate (Dr.-Ing.)',
    },
    {
      '@type': 'EducationalOccupationalCredential',
      credentialCategory: locale === 'de'
        ? 'Öffentlich bestellter und vereidigter Sachverständiger'
        : 'Court-appointed and sworn expert',
    },
  ],
};

const orgNode = {
  '@type': 'Organization',
  '@id': 'https://www.fb-zent.com/#org',
  name: 'BBA GmbH',
  legalName: 'BBA GmbH',
  url: 'https://www.fb-zent.com/',
  email: 'info@bba-badsaarow.de',
  telephone: '+49 174 4935860',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Silberberger Chaussee 14',
    postalCode: '15526',
    addressLocality: 'Bad Saarow',
    addressRegion: 'BB',
    addressCountry: 'DE',
  },
  founder: { '@id': 'https://www.fb-zent.com/#founder' },
  vatID: 'DE188194413',
  taxID: 'HRB 17338',
  areaServed: [
    { '@type': 'Country', name: 'Germany' },
    { '@type': 'Country', name: 'Austria' },
    { '@type': 'Country', name: 'Switzerland' },
  ],
  contactPoint: [
    {
      '@type': 'ContactPoint',
      contactType: 'sales',
      telephone: '+49 174 4935860',
      email: 'info@bba-badsaarow.de',
      availableLanguage: ['de', 'en'],
      areaServed: ['DE', 'AT', 'CH'],
    },
    {
      '@type': 'ContactPoint',
      contactType: 'customer service',
      telephone: '+49 33631 58374',
      email: 'info@bba-badsaarow.de',
      availableLanguage: ['de'],
    },
  ],
};

const productNode = {
  '@type': 'Product',
  '@id': 'https://www.fb-zent.com/#product',
  name: 'FBZ Fugenblechzentrierung',
  alternateName: locale === 'de' ? 'Fugenblech-Zentrierhilfe' : 'Waterstop Centering Element',
  description: t.meta.description,
  image: ['https://www.fb-zent.com/rendering-fbz-1200.png'],
  sku: 'FBZ-001',
  mpn: 'FBZ-001',
  brand: { '@id': 'https://www.fb-zent.com/#org' },
  manufacturer: { '@id': 'https://www.fb-zent.com/#org' },
  category: 'Construction / Waterproofing / Concrete joint sealing',
  material: locale === 'de' ? 'Schaumstoff-Formteil' : 'Moulded foam element',
  additionalProperty: [
    { '@type': 'PropertyValue', name: locale === 'de' ? 'Patent angemeldet' : 'Patent pending', value: 'DE 10 2025 121 129.9' },
    { '@type': 'PropertyValue', name: locale === 'de' ? 'Einbauzeit' : 'Install time', value: locale === 'de' ? '< 1 Minute pro Laufmeter' : '< 1 minute per linear meter' },
    { '@type': 'PropertyValue', name: locale === 'de' ? 'Werkzeugbedarf' : 'Tooling required', value: locale === 'de' ? 'Keiner' : 'None' },
    { '@type': 'PropertyValue', name: locale === 'de' ? 'Einsatzbereich' : 'Application', value: locale === 'de' ? 'WU-Konstruktionen, Arbeitsfuge Bodenplatte/Wand' : 'Watertight concrete, base-slab-to-wall joints' },
  ],
  offers: {
    '@type': 'Offer',
    url: canonical + '#contact',
    priceSpecification: {
      '@type': 'PriceSpecification',
      priceCurrency: 'EUR',
      description: locale === 'de' ? 'Preis auf Anfrage' : 'Price on request',
    },
    availability: 'https://schema.org/InStock',
    itemCondition: 'https://schema.org/NewCondition',
    businessFunction: 'https://schema.org/Sell',
    areaServed: ['DE', 'AT', 'CH'],
    seller: { '@id': 'https://www.fb-zent.com/#org' },
  },
};

const websiteNode = {
  '@type': 'WebSite',
  '@id': 'https://www.fb-zent.com/#website',
  url: 'https://www.fb-zent.com/',
  name: 'FBZ Fugenblechzentrierung',
  description: locale === 'de'
    ? 'Patentangemeldete Schaumstoff-Zentrierhilfe, die Fugenbleche in der Arbeitsfuge von WU-Konstruktionen millimetergenau positioniert und während des Betoniervorgangs sicher in Lage hält.'
    : 'Patent-pending foam centering element that positions waterstop sheets dead-center in the construction joint of watertight concrete structures and holds them securely throughout the entire pour.',
  publisher: { '@id': 'https://www.fb-zent.com/#org' },
  inLanguage: ['de-DE', 'en-US'],
};

const videoNode = {
  '@type': 'VideoObject',
  '@id': 'https://www.fb-zent.com/#video-fbz-de',
  name: 'FBZ Fugenblechzentrierung – Einbau auf der Baustelle',
  description: 'Produktvideo zur Fugenblechzentrierung (FBZ): Einbau auf der Arbeitsfuge zwischen Bodenplatte und aufgehender Wand in einer WU-Konstruktion. Drei Schritte – Positionieren, Einstecken, Betonieren – in unter einer Minute pro Laufmeter.',
  thumbnailUrl: [
    'https://www.fb-zent.com/video-poster-r2-800.webp',
    'https://www.fb-zent.com/video-poster-r2-1280.webp',
    'https://www.fb-zent.com/video-poster-r2-1600.webp',
  ],
  contentUrl: 'https://oatucv4cwba4mznn.public.blob.vercel-storage.com/FBZ_2026_deutsch_720p_h264.mp4',
  uploadDate: '2026-04-29',
  duration: 'PT2M30S',
  inLanguage: 'de',
  isFamilyFriendly: true,
  publisher: { '@id': 'https://www.fb-zent.com/#org' },
  about: { '@id': 'https://www.fb-zent.com/#product' },
  hasPart: [
    {
      '@type': 'Clip',
      name: 'Schritt 1 – Positionieren',
      startOffset: 0,
    },
    {
      '@type': 'Clip',
      name: 'Schritt 2 – Einstecken',
      startOffset: 50,
    },
    {
      '@type': 'Clip',
      name: 'Schritt 3 – Betonieren',
      startOffset: 100,
    },
  ],
};

const faqDe = {
  '@type': 'FAQPage',
  '@id': 'https://www.fb-zent.com/#faq',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Was ist die FBZ Fugenblechzentrierung?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Die FBZ ist ein patentangemeldetes Formteil aus Schaumstoff, das Fugenbleche exakt mittig in der Arbeitsfuge einer WU-Konstruktion positioniert und während des Betoniervorgangs sicher in Lage hält. Sie reduziert eine häufige Ausführungsfehlerquelle am Boden-Wand-Anschluss.',
      },
    },
    {
      '@type': 'Question',
      name: 'Wo entstehen Leckagen bei WU-Konstruktionen am häufigsten?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Nach Sachverständigenerfahrung sind Undichtigkeiten bei Weißen Wannen häufig auf fehlerhaft geplante oder ausgeführte Durchdringungen, Öffnungen, Fugen und Anschlüsse zurückzuführen. Besonders kritisch ist die Arbeitsfuge zwischen Bodenplatte und aufgehender Wand. Typische Ausführungsfehler am Fugenblech: Lageverschiebung beim Betonieren, zu geringer Abstand zur Bewehrung, mangelhafte Zentrierung, falsche Einbindetiefe und beschädigte Beschichtung.',
      },
    },
    {
      '@type': 'Question',
      name: 'Wie viel Zeit spart die FBZ beim Einbau?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Die Einbauzeit liegt unter einer Minute pro Laufmeter. Es werden keine Spezialwerkzeuge benötigt und jeder Bauarbeiter kann die FBZ nach einer kurzen Einweisung einsetzen.',
      },
    },
    {
      '@type': 'Question',
      name: 'Für welche Bauvorhaben eignet sich die FBZ?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Die FBZ ist für alle WU-Konstruktionen im Bodenplatten-Wandbereich geeignet: Tiefgaragenböden im Bodenplatten-Wandanschlussbereich, Keller und Untergeschosse mit Grundwasserbeanspruchung, Industriebauten mit wasserdichten Betonkonstruktionen sowie Systembau-Projekte mit engen Taktzeiten.',
      },
    },
    {
      '@type': 'Question',
      name: 'Was kostet eine Instandsetzung bei undichter Arbeitsfuge?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Eine nachträgliche Instandsetzung liegt pro Schadensfall regelmäßig im fünf- bis sechsstelligen Bereich – zuzüglich Nutzungsausfall, Gutachten und möglicher Rechtsstreitigkeiten. Die FBZ kostet pro Laufmeter einen Bruchteil davon.',
      },
    },
    {
      '@type': 'Question',
      name: 'Wer hat die FBZ entwickelt?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Die FBZ wurde von Dr. Ing. Jörn Budde (BBA GmbH, Bad Saarow) entwickelt – Sachverständiger für Gebäudeabdichtung und Bautenschutz mit langjähriger Begutachtungspraxis am Boden-Wand-Anschluss. Das Produkt ist zum Patent angemeldet (DE 10 2025 121 129.9).',
      },
    },
  ],
};

const faqEn = {
  '@type': 'FAQPage',
  '@id': 'https://www.fb-zent.com/#faq',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is the FBZ waterstop centering element?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The FBZ is a patent-pending moulded foam element that positions waterstop sheets dead-center in the construction joint of watertight concrete structures and holds them securely throughout the pour. It reduces a common installation error at the base-slab-to-wall joint.',
      },
    },
    {
      '@type': 'Question',
      name: 'Where do leaks in watertight concrete structures typically occur?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Expert practice shows that leaks in watertight concrete structures usually trace back to poorly designed or executed penetrations, openings, joints and connections. The construction joint between base slab and rising wall is especially critical. Typical installation errors at the waterstop: displacement during the pour, insufficient rebar clearance, poor centering, wrong embedment depth and coating damage.',
      },
    },
    {
      '@type': 'Question',
      name: 'How much time does the FBZ save during installation?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Installation takes under one minute per linear meter. No special tools are required and any worker can install the FBZ after a brief instruction.',
      },
    },
    {
      '@type': 'Question',
      name: 'For which projects is the FBZ suitable?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The FBZ is suitable for any watertight concrete structure at the base-slab-to-wall joint: underground car park floors at the base slab-to-wall junction, basements and cellars exposed to groundwater, industrial buildings with watertight concrete, and system-build projects with tight schedules.',
      },
    },
    {
      '@type': 'Question',
      name: 'What does retroactive remediation of a leaking joint cost?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Retroactive remediation regularly runs in the five- to six-figure range per case — plus loss of use, expert reports and potential legal disputes. The FBZ costs a fraction of that per linear meter.',
      },
    },
    {
      '@type': 'Question',
      name: 'Who developed the FBZ?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The FBZ was developed by Dr. Ing. Jörn Budde (BBA GmbH, Bad Saarow), expert for building waterproofing and structural protection with long-standing case practice at the base-to-wall joint. The product is patent-pending (DE 10 2025 121 129.9).',
      },
    },
  ],
};

const homeGraph = locale === 'de'
  ? [founderNode, orgNode, websiteNode, productNode, videoNode, faqDe]
  : [founderNode, orgNode, websiteNode, productNode, faqEn];

const graph = pageType === 'home'
  ? homeGraph
  : [founderNode, orgNode, websiteNode];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': graph,
};
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <link rel="alternate" hreflang={locale} href={canonical} />
    <link rel="alternate" hreflang={altLocale} href={altHref} />
    <link rel="alternate" hreflang="x-default" href="https://www.fb-zent.com/" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="FBZ Fugenblechzentrierung" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={t.meta.ogAlt} />
    <meta property="og:locale" content={locale === 'de' ? 'de_DE' : 'en_US'} />
    <meta property="og:locale:alternate" content={locale === 'de' ? 'en_US' : 'de_DE'} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="theme-color" content="#f7f8f9" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="128x128" href="/logo-fbz.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    {pageType === 'home' && (
      <link
        rel="preload"
        as="image"
        href="/video-poster-r2-1280.webp"
        imagesrcset="/video-poster-r2-800.webp 800w, /video-poster-r2-1280.webp 1280w, /video-poster-r2-1600.webp 1600w"
        imagesizes="(min-width: 1024px) 60vw, 100vw"
        type="image/webp"
        fetchpriority="high"
      />
    )}
    <link rel="preload" as="font" href="/fonts/satoshi-400.woff2" type="font/woff2" crossorigin />
    <link rel="preload" as="font" href="/fonts/clash-display-600.woff2" type="font/woff2" crossorigin />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:bg-ink focus:text-paper focus:px-4 focus:py-2">
      {locale === 'de' ? 'Zum Inhalt springen' : 'Skip to content'}
    </a>
    <slot />
    {pageType === 'home' && <WebMCP locale={locale} />}
  </body>
</html>
