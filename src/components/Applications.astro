---
import type { Locale } from '~/i18n/content';
import { content } from '~/i18n/content';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = content[locale].applications;
---

<section class="py-[clamp(5rem,10vw,9rem)] border-t border-ink-line">
  <div class="grid-frame">
    <div class="col-span-12 lg:col-span-4">
      <span class="label-blue">{t.eyebrow}</span>
      <h2 class="mt-6 text-display-md font-display font-semibold leading-[1.02] text-balance">
        {t.headline}
      </h2>
    </div>

    <ul class="col-span-12 lg:col-span-8 mt-6 lg:mt-0 lg:pt-4 space-y-0 divide-y divide-ink-line border-t border-b border-ink-line">
      {t.items.map((item, i) => (
        <li class="flex items-baseline gap-6 py-6 md:py-7 group hover:pl-2 transition-all duration-300">
          <span class="font-mono text-[0.75rem] tracking-wider text-ink-mute shrink-0 w-8">
            0{i + 1}
          </span>
          <span class="font-display text-xl md:text-2xl font-medium leading-tight text-balance flex-1">
            {item}
          </span>
          <span class="text-ink-mute text-xl opacity-0 group-hover:opacity-100 transition-opacity duration-300">→</span>
        </li>
      ))}
    </ul>
  </div>
</section>
