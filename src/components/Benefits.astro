---
import type { Locale } from '~/i18n/content';
import { content } from '~/i18n/content';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = content[locale].benefits;
---

<section id="benefits" class="py-[clamp(5rem,10vw,9rem)] border-t border-ink-line">
  <div class="grid-frame">
    <div class="col-span-12 md:col-span-8 lg:col-span-6">
      <span class="label-blue">{t.eyebrow}</span>
      <h2 class="mt-6 text-display-lg font-display font-semibold leading-[0.98] text-balance">
        {t.headline}
      </h2>
    </div>

    <!-- Editorial list, not card grid -->
    <dl class="col-span-12 mt-16 md:mt-24 divide-y divide-ink-line border-t border-b border-ink-line">
      {t.items.map((item, i) => (
        <div class="grid grid-cols-12 gap-4 md:gap-8 py-8 md:py-10 group">
          <div class="col-span-2 md:col-span-1 font-mono text-[0.75rem] tracking-wider text-ink-mute pt-1">
            0{i + 1}
          </div>
          <dt class="col-span-10 md:col-span-5 font-display text-2xl md:text-[2rem] font-semibold leading-[1.05] tracking-tight">
            {item.title}
          </dt>
          <dd class="col-span-12 md:col-span-6 text-ink-soft text-[1.0625rem] leading-relaxed max-w-[50ch]">
            {item.body}
          </dd>
        </div>
      ))}
    </dl>
  </div>
</section>
