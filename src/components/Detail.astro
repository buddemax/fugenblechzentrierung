---
import type { Locale } from '~/i18n/content';
import { content } from '~/i18n/content';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = content[locale].detail;
---

<section
  id="detail"
  class="py-[clamp(5rem,10vw,9rem)] border-t border-ink-line relative overflow-hidden"
>
  <!-- Faint technical drawing grid -->
  <div class="absolute inset-0 pointer-events-none opacity-[0.5]" aria-hidden="true">
    <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="detail-grid" width="64" height="64" patternUnits="userSpaceOnUse">
          <path d="M 64 0 L 0 0 0 64" fill="none" stroke="oklch(90% 0.005 230)" stroke-width="1" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#detail-grid)" />
    </svg>
  </div>

  <div class="grid-frame relative">
    <!-- Section header -->
    <div class="col-span-12 md:col-span-6 lg:col-span-5">
      <div class="flex items-center gap-4 mb-8 md:mb-10">
        <span class="label-blue">{t.label}</span>
        <span class="h-px flex-1 bg-ink-line max-w-[120px]"></span>
        <span class="label">{t.eyebrow}</span>
      </div>
      <h2 class="text-display-lg font-display font-semibold leading-[0.96] tracking-tight text-balance">
        {t.headline}
      </h2>
      <p class="mt-8 md:mt-10 text-ink-soft text-[1.0625rem] md:text-lg leading-[1.55] max-w-[44ch]">
        {t.lead}
      </p>

      <!-- Annotation list (technical spec table styling) -->
      <dl class="mt-12 md:mt-16 divide-y divide-ink-line border-t border-ink-line">
        {t.annotations.map((row) => (
          <div class="grid grid-cols-12 gap-4 py-4">
            <dt class="col-span-5 label text-[0.6875rem] pt-1">{row.k}</dt>
            <dd class="col-span-7 font-display text-base md:text-lg font-medium text-ink leading-tight tracking-tight">
              {row.v}
            </dd>
          </div>
        ))}
      </dl>

      <p class="mt-10 font-mono text-[0.75rem] tracking-[0.16em] uppercase text-ink-mute">
        {t.note}
      </p>
    </div>

    <!-- Rendering composition -->
    <div class="col-span-12 md:col-span-6 lg:col-start-7 lg:col-span-6 mt-16 md:mt-0 relative">
      <div class="relative lg:-mt-8 xl:-mt-12">
        <!-- Outer dimension brackets (top-left + bottom-right tick marks) -->
        <div class="hidden md:block absolute -top-2 left-0 right-0 h-3 pointer-events-none" aria-hidden="true">
          <div class="absolute left-0 top-0 w-px h-full bg-ink-soft"></div>
          <div class="absolute right-0 top-0 w-px h-full bg-ink-soft"></div>
          <div class="absolute left-0 right-0 top-1/2 h-px bg-ink-line"></div>
        </div>

        <div class="relative aspect-square">
          <span class="corner-mark corner-mark--tl"></span>
          <span class="corner-mark corner-mark--tr"></span>
          <span class="corner-mark corner-mark--bl"></span>
          <span class="corner-mark corner-mark--br"></span>

          <picture>
            <source srcset="/rendering-fbz.webp" type="image/webp" />
            <img
              src="/rendering-fbz-1200.png"
              alt={t.imgAlt}
              width="1200"
              height="1200"
              loading="lazy"
              decoding="async"
              class="w-full h-full object-contain select-none"
              draggable="false"
            />
          </picture>

          <!-- Mid-axis crosshair as subtle drawing reference -->
          <div class="absolute inset-0 pointer-events-none opacity-[0.18]" aria-hidden="true">
            <div class="absolute left-1/2 top-0 bottom-0 w-px bg-ink-soft"></div>
            <div class="absolute top-1/2 left-0 right-0 h-px bg-ink-soft"></div>
          </div>
        </div>

        <!-- Mono caption beneath rendering -->
        <div class="mt-3 md:mt-4 flex items-baseline justify-between gap-4 border-t border-ink-line pt-3">
          <span class="font-mono text-[0.6875rem] tracking-[0.16em] uppercase text-ink-mute font-medium">
            FBZ — {t.label}
          </span>
          <span class="font-mono text-[0.6875rem] tracking-[0.16em] uppercase text-ink-mute font-medium">
            Render · ISO
          </span>
        </div>
      </div>
    </div>
  </div>
</section>
